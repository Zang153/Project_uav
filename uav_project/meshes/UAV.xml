<?xml version='1.0' encoding='utf-8'?>
<mujoco model="Delta">
  
  <compiler angle="radian" meshdir="assets" />
  <option timestep="0.001" gravity="0 0 -9.81" integrator="implicit" iterations="100" density="1" viscosity="1e-5" />

  <default>
    <joint type="hinge" frictionloss="0.0001" damping="0.00005" limited="true" range="-3.14 3.14" />
    <position ctrllimited="false" forcelimited="false" kp="100" kv="10" />
  </default>

  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3" rgb2=".2 .3 .4" width="100" height="100" />
    <material name="grid" texture="grid" texrepeat="5 5" reflectance="0.0" />
  </asset>

  <worldbody>
    
    <geom pos="0 0 0" size="0 0 0.05" type="plane" material="grid" />
    
    <light pos="0 0 10." />


    <body name="UAV_Delta_platform" pos="0 0 0.13271" quat="1. 0. 0. 0">
      <freejoint />
      <body name="UAV_body" pos="0 0 0.04" quat="1. 0. 0. 0">
        <site name="imu" />
        <site name="UAV_center" pos=" 0 0 0" size="0.01" quat="1.0 0.0 0.0 0." rgba="0.8 0.8 0.3 1" />
        <geom name="core" type="box" pos="0 0 0" quat="1. 0. 0. 0" size="0.06 0.035 0.025" rgba="0.3 0.3 0.3 0.3" mass=".2" />
        <geom name="a00" type="box" pos=".071 0.071 0" size="0.15 0.01 0.0025" quat=".924 0.0 0.0 0.383" rgba="0.3 0.3 0.8 1" mass=".025" />
        <geom name="a10" type="box" pos=".071 -0.071 0" size="0.15 0.01 0.0025" quat=".383 0.0 0.0 0.924" rgba="0.3 0.3 0.8 1" mass=".025" />
        <geom name="a20" type="box" pos="-0.071 -0.071 0" size="0.15 0.01 0.0025" quat="-.383 0.0 0.0 0.924" rgba="0.3 0.3 0.8 1" mass=".025" />
        <geom name="a30" type="box" pos="-.071 0.071 0" size="0.15 0.01 0.0025" quat=".924 0.0 0.0 -0.383" rgba="0.3 0.3 0.8 1" mass=".025" />

        <site name="motor1" type="cylinder" pos=" 0.18  0.18 0.01" size="0.01 0.0025" quat="1.0 0.0 0.0 0." rgba="0.3 0.8 0.3 1" />
        <site name="motor2" type="cylinder" pos=" 0.18 -0.18 0.01" size="0.01 0.0025" quat="1.0 0.0 0.0 0." rgba="0.3 0.8 0.3 1" />
        <site name="motor3" type="cylinder" pos="-0.18 -0.18 0.01" size="0.01 0.0025" quat="1.0 0.0 0.0 0." rgba="0.3 0.8 0.3 1" />
        <site name="motor4" type="cylinder" pos="-0.18  0.18 0.01" size="0.01 0.0025" quat="1.0 0.0 0.0 0." rgba="0.3 0.8 0.3 1" />

        
        <geom name="prop1" type="cylinder" pos=" 0.18  0.18  0.01" size="0.1 0.0025" quat="1.0 0.0 0.0 0." rgba="1 0 0 1" mass=".025" />
        <geom name="prop2" type="cylinder" pos=" 0.18  -0.18  0.01" size="0.1 0.0025" quat="1.0 0.0 0.0 0." rgba="0 0.3 1 1" mass=".025" />
        <geom name="prop3" type="cylinder" pos=" -0.18  -0.18  0.01" size="0.1 0.0025" quat="1.0 0.0 0.0 0." rgba="1 0 0.8 1" mass=".025" />
        <geom name="prop4" type="cylinder" pos=" -0.18  0.18  0.01" size="0.1 0.0025" quat="1.0 0.0 0.0 0." rgba="0.3 0.8 0.3 1" mass=".025" />
      </body>
      <camera name="track" pos="0 -1. .3" xyaxes="1 0 0 0 1 2" mode="track" />
      </body>

    </worldbody>

  <actuator>
    

    <!-- Disable direct force/torque actuation -->
    <!-- <motor name="forcex" gear="1 0 0 0 0 0" site="UAV_center" /> 
    <motor name="forcey" gear="0 1 0 0 0 0" site="UAV_center" /> 
    <motor name="forcez" gear="0 0 1 0 0 0" site="UAV_center" /> 
    <motor name="Mx" gear="0 0 0 1 0 0" site="UAV_center" /> 
    <motor name="My" gear="0 0 0 0 1 0" site="UAV_center" /> 
    <motor name="Mz" gear="0 0 0 0 0 1" site="UAV_center" /> -->

    <!-- 
      gear="0 0 Ct 0 0 Cm" 
      From config.py: Ct = 0.01343, Cm = 0.0003099 (rounded to 0.00031)
      Rotor 0, 2: CCW -> -Cm
      Rotor 1, 3: CW  -> +Cm
    -->
    <motor name="rotor0" gear="0 0 0.01343 0. 0. -0.00031" site="motor1" />
    <motor name="rotor1" gear="0 0 0.01343 0. 0.  0.00031" site="motor2" />
    <motor name="rotor2" gear="0 0 0.01343 0. 0. -0.00031" site="motor3" />
    <motor name="rotor3" gear="0 0 0.01343 0. 0.  0.00031" site="motor4" />    
      
    </actuator>  
  
  <sensor>
    <gyro name="body_gyro" site="imu" />
    <accelerometer name="body_linacc" site="imu" />
    <framequat name="body_quat" objtype="site" objname="imu" />  

    </sensor>  

  <visual>
    <global offwidth="1920" offheight="1680" />
  </visual>

</mujoco>